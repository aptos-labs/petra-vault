{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": [".next/**", "!.next/cache/**", "out/**"],
      "env": ["SENTRY_AUTH_TOKEN", "NEXT_RUNTIME"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": ["APTOS_DEVNET_FAUCET_AUTH_TOKEN"]
    }
  }
}
